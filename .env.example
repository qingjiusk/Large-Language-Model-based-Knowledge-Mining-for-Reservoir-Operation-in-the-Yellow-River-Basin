# ============================================
# HydroBrain 环境变量模板
# 复制此文件为 .env 后填入真实值
# ============================================

# ---------- DeepSeek API ----------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- Neo4j 图数据库 ----------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
